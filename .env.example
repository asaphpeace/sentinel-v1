# Copy to .env and fill in values before running docker-compose up

# ── Required ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-run-openssl-rand-hex-32
POSTGRES_PASSWORD=change-me-strong-password
APP_BASE_URL=https://app.yourdomain.com

# ── CORS (comma-separated, must include your frontend origin) ─────────────────
CORS_ORIGINS=https://app.yourdomain.com

# ── IMAP for DMARC/TLS-RPT report ingestion ──────────────────────────────────
IMAP_HOST=mail.mailsentry.co.za
IMAP_PORT=993
IMAP_USER=reports@mailsentry.co.za
IMAP_PASSWORD=

# ── Sentinel reporting domain ─────────────────────────────────────────────────
REPORTING_DOMAIN=mailsentry.co.za
MTA_STS_HOSTING_CNAME_TARGET=mta-sts-host.mailsentry.co.za

# ── AI Advisor ────────────────────────────────────────────────────────────────
# Set ADVISOR_PROVIDER=claude and supply ANTHROPIC_API_KEY for production
ADVISOR_PROVIDER=claude
ANTHROPIC_API_KEY=
ADVISOR_CLAUDE_MODEL=claude-haiku-4-5-20251001
ADVISOR_ENABLED=true

# ── Stripe ────────────────────────────────────────────────────────────────────
# Leave blank to run with billing disabled (checkout returns 503)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_MSP_MONTHLY=price_...
STRIPE_PRICE_MSP_ANNUAL=price_...

# ── SendGrid ──────────────────────────────────────────────────────────────────
# Leave blank for local dev — emails are logged, not sent
SENDGRID_API_KEY=SG....
EMAIL_FROM_ADDRESS=noreply@mailsentry.co.za
EMAIL_FROM_NAME=Sentinel

# ── Port exposed on host (default 80) ────────────────────────────────────────
PORT=80
