DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
# 60 minutes — tokens are stateless JWTs with no server-side revocation other
# than the token_version bump on password/2FA change (see User.token_version).
ACCESS_TOKEN_EXPIRE_MINUTES=60

# IMAP settings for DMARC/TLS-RPT report ingestion
IMAP_HOST=mail.mailsentry.co.za
IMAP_PORT=993
IMAP_USER=reports@mailsentry.co.za
IMAP_PASSWORD=

# Reporting domain — unique subaddress per customer domain is appended here
REPORTING_DOMAIN=mailsentry.co.za

# Managed MTA-STS hosting CNAME target — customers on hosting_mode=managed
# publish mta-sts.<their-domain> as a CNAME to this hostname; bare hostname,
# not a URL (see app/routers/mta_sts_hosting.py)
MTA_STS_HOSTING_CNAME_TARGET=mta-sts-host.mailsentry.co.za

# Frontend origin the backend redirects/links to (invite links, reset
# links, verification links, CORS default)
APP_BASE_URL=http://localhost:5173

# Comma-separated list of allowed frontend origins for CORS. Production
# must set this explicitly — never "*" combined with credentials.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Advisor LLM — "ollama" (local, default) or "claude" (set ANTHROPIC_API_KEY)
ADVISOR_LLM_URL=http://localhost:11434
ADVISOR_LLM_MODEL=sentinel:latest
ADVISOR_ENABLED=true
ADVISOR_PROVIDER=ollama
ANTHROPIC_API_KEY=
ADVISOR_CLAUDE_MODEL=claude-haiku-4-5-20251001

# Background job intervals (seconds)
IMAP_POLL_INTERVAL=300
CERT_PROBE_INTERVAL=86400
DNS_POLL_INTERVAL=3600
RECOMMENDATION_INTERVAL=86400
SCHEDULED_REPORT_CHECK_INTERVAL=86400

# Stripe — leave blank to run with billing disabled (checkout endpoints
# return 503 rather than failing in some less-obvious way)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_MSP_MONTHLY=
STRIPE_PRICE_MSP_ANNUAL=

# Transactional email — SendGrid REST API via httpx (no SDK dependency).
# Leave SENDGRID_API_KEY blank for local dev: emails are logged instead of
# sent, so nothing in this codebase requires a real key to run.
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=noreply@mailsentry.co.za
EMAIL_FROM_NAME=Sentinel
